# config.env — copy to config.env, edit, then `set -a; source config.env; set +a`.
# This file is git-ignored.

# ── Virtual env ──
# Absolute path to the venv containing vLLM / flash-attn / transformers / verl / bfcl-eval / etc.
# If unset or missing, system Python is used.
# export EVAL_VENV=/abs/path/to/.eval
# export SKIP_EVAL_VENV=0

# ── Cache base (single knob for HF / Triton / FlashInfer / vLLM / Torch) ──
# Must have at least ~50 GB free on the filesystem it lives on.
# export CACHE_BASE=$HOME/.cache/rl_merging_eval

# ── Evaluation data (parquet files for AIME / IFEval) ──
# Expected layout:
#   $EVAL_DATA_ROOT/aime24/test_verl_ready_with_instruction.parquet
#   $EVAL_DATA_ROOT/aime25/test_verl_ready_with_instruction.parquet
#   $EVAL_DATA_ROOT/aime26/test_verl_ready_with_instruction.parquet
# export EVAL_DATA_ROOT=/abs/path/to/eval_data

# ── VERL checkout containing the custom AIME reward (see README §3-4) ──
# Must expose verl/utils/reward_score/aime.py, grader.py, __init__.py and
# verl/workers/reward_manager/naive.py with the custom patterns.
# export NEMOTRON_REPO_ROOT=/abs/path/to/verl_nemotron_merge

# ── Output roots ──
# VERL (AIME, IFEval) puts artifacts here. Default: ./results/verl_outputs.
# export OUTPUT_ROOT=/abs/path/to/eval_outputs

# ── Temp dirs (MUST be on local disk, not NFS) ──
# export TMPDIR=/tmp/eval_tmp_$USER
# export RAY_TMPDIR=/tmp/ray_$USER

# ── BFCL knobs (Tool_use) ──
# export BFCL_DTYPE=bfloat16         # or float16
# export BFCL_PROMPT_MODE=tool       # or plain

# ── vLLM + Ray verbosity ──
# export VLLM_LOGGING_LEVEL=WARNING
# export WANDB_MODE=disabled
